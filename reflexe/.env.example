# ============================================================================
# REFLEXE — Variables d'environnement
# Copier ce fichier en `.env` puis renseigner les valeurs. NE JAMAIS committer .env.
# ============================================================================

# --- Anthropic (OBLIGATOIRE pour le scoring ICP et la rédaction des messages) ---
# Clé API depuis https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=

# --- Pappers (OPTIONNEL — enrichissement légal : dirigeants, site web déclaré) ---
# Clé depuis https://www.pappers.fr/api  (sans clé, cette source est sautée proprement)
PAPPERS_API_KEY=

# --- Brevo (OPTIONNEL — pour pousser les prospects validés en CRM) ---
# Clé depuis https://app.brevo.com/ -> SMTP & API -> API Keys
BREVO_API_KEY=
# Identifiant(s) de liste Brevo où ajouter les contacts (séparés par des virgules).
# Peut aussi être défini par mission. Ex : 12  ou  12,15
BREVO_LIST_IDS=

# --- Vérification d'email (OPTIONNEL) ---
# Si une clé d'un service de vérification est fournie, elle est utilisée en complément
# de la vérification locale (syntaxe + MX). Sinon, vérification locale uniquement.
EMAIL_VERIFY_API_KEY=

# --- Modèles Claude (OPTIONNEL — valeurs par défaut adaptées) ---
# Scoring (rapide / peu cher) et rédaction des messages (qualité).
REFLEXE_MODELE_SCORING=claude-haiku-4-5
REFLEXE_MODELE_MESSAGE=claude-sonnet-4-6

# --- Comportement réseau (OPTIONNEL) ---
# Délai poli minimal entre deux requêtes sur un même domaine (secondes).
REFLEXE_DELAI_DOMAINE=1.5
# Nombre maximum de requêtes HTTP concurrentes (tous domaines confondus).
REFLEXE_CONCURRENCE_MAX=8
# User-Agent annoncé lors du crawl des sites publics.
REFLEXE_USER_AGENT=ReflexeBot/0.1 (+prospection B2B; contact via site)

# --- Chemins (OPTIONNEL — valeurs par défaut adaptées au dépôt) ---
REFLEXE_DATA_DIR=data
REFLEXE_LOGS_DIR=logs
REFLEXE_LOG_LEVEL=INFO
