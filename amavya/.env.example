# --- SMTP OVH pour notification du formulaire de contact ---
# À copier dans Vercel : Settings → Environment Variables
# Une fois la boîte contact@amavya.cloud créée sur OVH MX Plan.

SMTP_HOST=ssl0.ovh.net
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=contact@amavya.cloud
SMTP_PASS=ton-mot-de-passe-OVH

# (Optionnel) Adresse qui reçoit la notification (défaut: contact@amavya.cloud)
CONTACT_TO=contact@amavya.cloud
# (Optionnel) From affiché dans le mail (défaut: AMAVYA — Site <SMTP_USER>)
CONTACT_FROM="AMAVYA — Site <contact@amavya.cloud>"

# --- Chatbot IA AMAVYA (étape 5) ---
# Clé API Anthropic — créer sur https://console.anthropic.com/
# Si absente : la bulle de chat ne s'affiche pas, le site reste 100% fonctionnel.
ANTHROPIC_API_KEY=sk-ant-api-...

# --- Supabase (formulaire contact / partner leads) ---
# Projet : dmztalsmreugfwojsaar
# La clé "anon" est publique côté client (RLS protège les données), mais on la
# garde quand même hors du repo pour pouvoir la rotater sans toucher au code.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
