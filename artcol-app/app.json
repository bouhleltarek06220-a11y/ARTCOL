{
  "expo": {
    "name": "ARTCOL",
    "slug": "artcol-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "artcol",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#080b10"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tarkus.artcol",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080b10"
      },
      "package": "com.tarkus.artcol",
      "versionCode": 1
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "ARTCOL a besoin d'accéder à tes photos pour mettre à jour ton avatar.",
          "cameraPermission": "ARTCOL a besoin de l'appareil photo pour prendre une photo de profil."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "GENERATED-BY-EAS-INIT"
      }
    }
  }
}
