# ============================================================================
# SENSOR — Variables d'environnement
# Copier ce fichier en `.env` puis renseigner les valeurs. NE JAMAIS committer .env.
# ============================================================================

# --- Anthropic (OBLIGATOIRE pour la génération de réponses) ---
# Clé API depuis https://console.anthropic.com/ -> Settings -> API Keys
ANTHROPIC_API_KEY=

# --- Clé d'administration de l'API SENSOR (OBLIGATOIRE) ---
# Sert à protéger les routes /admin/* (ingestion, stats, purge).
# Générer une valeur aléatoire forte, ex: `python -c "import secrets;print(secrets.token_urlsafe(32))"`
SENSOR_ADMIN_KEY=

# --- Embeddings via API (OPTIONNEL — seulement si un client utilise embedder: api) ---
# Voyage AI : https://www.voyageai.com/  (clé dans le dashboard)
VOYAGE_API_KEY=
# Modèle Voyage par défaut (multilingue, bonne qualité).
VOYAGE_MODEL=voyage-3

# --- Supabase pgvector (OPTIONNEL — seulement si un client utilise vectorstore: supabase) ---
# Projet Supabase -> Settings -> API. Utiliser la clé service_role (côté serveur uniquement).
SUPABASE_URL=
SUPABASE_KEY=

# --- Chemins (OPTIONNEL — valeurs par défaut adaptées au dépôt) ---
# Répertoire des données runtime (bases vectorielles + conversations).
SENSOR_DATA_DIR=data
# Répertoire des logs rotatifs.
SENSOR_LOGS_DIR=logs
# Répertoire des configurations client YAML.
SENSOR_CLIENTS_DIR=clients

# --- Serveur API (OPTIONNEL) ---
SENSOR_HOST=0.0.0.0
SENSOR_PORT=8000
# Niveau de log console (DEBUG, INFO, WARNING, ERROR).
SENSOR_LOG_LEVEL=INFO
